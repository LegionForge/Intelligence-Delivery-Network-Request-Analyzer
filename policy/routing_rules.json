{
  "_meta": {
    "version": "0.2.0",
    "description": "Tier routing thresholds and scoring rules for IDN Request Analyzer"
  },
  "tiers": {
    "L0": {
      "description": "On-device inference",
      "complexity_max": 0.25,
      "token_max": 200,
      "reasoning_hops_max": 1,
      "domains": [
        "general"
      ],
      "force_conditions": [
        "offline_mode",
        "data_egress_blocked",
        "compliance_flag"
      ]
    },
    "L1": {
      "description": "Edge inference",
      "complexity_max": 0.45,
      "token_max": 500,
      "reasoning_hops_max": 2,
      "domains": [
        "general",
        "creative",
        "coding"
      ]
    },
    "L2": {
      "description": "Regional cloud inference",
      "complexity_max": 0.72,
      "token_max": 4000,
      "reasoning_hops_max": 3,
      "domains": [
        "coding",
        "research",
        "finance",
        "health",
        "agentic",
        "creative"
      ]
    },
    "L3": {
      "description": "Global frontier inference",
      "complexity_min": 0.72,
      "token_min": 4000,
      "reasoning_hops_min": 4,
      "domains": [
        "legal",
        "research",
        "coding"
      ]
    }
  },
  "complexity_scoring": {
    "version": "0.2.0",
    "base": 0.0,
    "weights": {
      "token_count_normalized": 0.2,
      "verb_density": 0.25,
      "question_count_normalized": 0.1,
      "list_item_count_normalized": 0.1,
      "sentence_count_normalized": 0.1,
      "domain_boost": 0.35
    },
    "normalization": {
      "token_count_max": 200,
      "verb_count_max": 10,
      "question_count_max": 5,
      "list_item_max": 10,
      "sentence_count_max": 10,
      "domain_boost_divisor": 3.0,
      "domain_boost_max": 0.35
    },
    "domain_complexity_floors": {
      "legal": 0.55,
      "health": 0.4,
      "finance": 0.46,
      "research": 0.46,
      "agentic": 0.46,
      "coding": 0.28,
      "coding_strong_match_threshold": 1.2,
      "coding_strong_match_floor": 0.46,
      "coding_high_match_threshold": 2.5,
      "coding_high_match_floor": 0.55,
      "creative": 0.2,
      "general": 0.0
    }
  },
  "confidence_scoring": {
    "base": 1.0,
    "penalties": {
      "token_count_ambiguous_range": {
        "min": 400,
        "max": 600,
        "penalty": -0.15
      },
      "multiple_domain_matches": {
        "penalty_per_extra_domain": -0.2
      },
      "pii_detected": {
        "penalty": -0.3
      },
      "quality_signals_with_uncertain_complexity": {
        "complexity_uncertain_range": [
          0.4,
          0.55
        ],
        "penalty": -0.2
      },
      "high_question_count": {
        "threshold": 3,
        "penalty": -0.15
      },
      "high_list_count": {
        "threshold": 5,
        "penalty": -0.1
      }
    },
    "escalation_threshold": 0.85,
    "force_escalate_conditions": [
      "compliance_flag",
      "pii_critical"
    ]
  },
  "output_types": {
    "text": "Prose, explanation, summary \u2014 default text response",
    "code": "Source code, scripts, queries, shell commands",
    "image": "Image generation request",
    "svg": "Vector graphic / icon / logo",
    "audio": "Music, speech, sound generation",
    "video": "Video or animation generation",
    "structured_data": "JSON, CSV, YAML, XML, tables, schemas",
    "mixed": "Combination of multiple output modalities",
    "model_decided": "Dealer's choice \u2014 model determines best output format"
  },
  "prompt_structure_signals": {
    "is_multi_step": {
      "description": "Prompt contains chained sequential instructions",
      "min_keyword_hits": 2,
      "keywords": [
        "then",
        "after that",
        "finally",
        "next",
        "step 1",
        "step 2",
        "first",
        "second",
        "third",
        "lastly",
        "followed by"
      ]
    },
    "is_numerical": {
      "description": "Prompt requires calculation, estimation, or quantitative output",
      "keywords": [
        "calculate",
        "compute",
        "how much",
        "how many",
        "percentage",
        "forecast",
        "estimate",
        "total",
        "average",
        "sum",
        "rate",
        "roi",
        "ebitda",
        "revenue",
        "cost",
        "budget",
        "price"
      ]
    },
    "is_conditional": {
      "description": "Prompt contains if/then branching logic",
      "keywords": [
        "if ",
        "unless",
        "assuming",
        "given that",
        "in the case",
        "when ",
        "depending on",
        "only if",
        "otherwise",
        "else"
      ]
    },
    "is_multimodal": {
      "description": "Prompt requests more than one output modality",
      "detection": "modality_count > 1"
    }
  },
  "reasoning_hop_estimation": {
    "single_verb_simple": 0,
    "single_verb_complex": 1,
    "multi_step_keywords": {
      "keywords": [
        "then",
        "after that",
        "next",
        "finally",
        "first",
        "second",
        "third",
        "step 1",
        "step 2",
        "also",
        "additionally",
        "furthermore"
      ],
      "hops_per_keyword": 0.5
    },
    "multi_task_keywords": {
      "keywords": [
        "and",
        "as well as",
        "in addition",
        "plus",
        "also"
      ],
      "hops_per_keyword": 0.3
    }
  }
}